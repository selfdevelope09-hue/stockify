.emotion-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.95);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.emotion-modal {
  background: #0a0a0a;
  border: 1px solid #1a1a1a;
  border-radius: 12px;
  width: 90%;
  max-width: 400px;
  padding: 20px;
}

.emotion-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.emotion-modal-header h3 {
  font-size: 18px;
  color: #fff;
}

.close-btn {
  background: none;
  border: none;
  color: #666;
  font-size: 20px;
  cursor: pointer;
}

.emotion-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}

.emotion-btn {
  background: #111111;
  border: 1px solid #1a1a1a;
  color: #fff;
  padding: 12px;
  border-radius: 8px;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.2s;
}

.emotion-btn.selected {
  background: var(--emotion-color);
  color: #000;
  border-color: var(--emotion-color);
}

.submit-btn {
  width: 100%;
  background: #ffffff;
  color: #000000;
  border: none;
  padding: 12px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.submit-btn:hover {
  opacity: 0.9;
}

.emotion-footer {
  text-align: center;
  margin-top: 12px;
  font-size: 10px;
  color: #444;
}
